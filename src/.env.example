# API Keys
OPENAI_API_KEY=your_openai_api_key_here
PEXELS_API_KEY=your_pexels_api_key_here

# Database Connection
# PostgreSQL connection string for AISystemBase database
# Format: postgresql://user:password@host:port/database
# Alternative format (for psycopg): postgresql+psycopg://user:password@host:port/database
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/AgentDatabase
# Alternative: DATABASE_URL can be used instead of POSTGRES_URL
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/AISystemBase

# Server Settings
APP_HOST=127.0.0.1
APP_PORT=7860

# Default Settings
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_STYLE=short-form
DEFAULT_DURATION=30

# Agent Settings
AGENT_MODEL=gpt-4o-mini
AGENT_TEMPERATURE=0.2
